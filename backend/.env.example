APP_NAME="Ansible Automation Console"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://ansible_tool:change_me@127.0.0.1:5432/ansible_tool
REDIS_URL=redis://127.0.0.1:6379/0
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
COOKIE_SECURE=false
COOKIE_DOMAIN=
SESSION_COOKIE_NAME=ansible_tool_session
CSRF_COOKIE_NAME=ansible_tool_csrf
SESSION_TTL_MINUTES=480
FERNET_KEY=replace_with_generated_fernet_key
RUNNER_DATA_DIR=/var/lib/ansible-tool/runner
ARTIFACT_RETENTION_DAYS=30
LDAP_ENABLED=true
LDAP_SERVER_URI=ldap://ldap.example.internal
LDAP_USE_SSL=false
LDAP_BIND_DN="CN=svc_ansible_tool,OU=Service Accounts,DC=example,DC=internal"
LDAP_BIND_PASSWORD=change_me
LDAP_SEARCH_BASE=OU=Users,DC=example,DC=internal
LDAP_SEARCH_FILTER=(sAMAccountName={username})
LDAP_USERNAME_ATTRIBUTE=sAMAccountName
LDAP_USER_DN_TEMPLATE=
ALLOW_LOCAL_AUTH=true
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=ChangeMe123!
AUTO_CREATE_DB=false
